# Postgres
DATABASE_URL="postgresql://todo:todo@localhost:5432/todo"

# Auth.js v5 secret — generate with: openssl rand -base64 32
# Must be named AUTH_SECRET (auto-detected by Auth.js v5)
AUTH_SECRET="replace-with-a-random-string"

# GitHub OAuth
# 1. Go to https://github.com/settings/developers
# 2. OAuth Apps → New OAuth App
# 3. Homepage URL: http://localhost:3000
# 4. Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 5. Copy the Client ID and generate a Client Secret below
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"
