generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  boards    Board[]
}

model Board {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns   Column[]
  tasks     Task[]
}

model Column {
  id        String   @id @default(cuid())
  title     String
  position  Float
  createdAt DateTime @default(now())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  position    Float
  createdAt   DateTime @default(now())
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
}
